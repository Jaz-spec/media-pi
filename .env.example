# -----------------------------------------------------------------------------
# ffmpeg input flags — the ONE thing that differs between Mac dev and Pi prod.
# Everything else in the Phase 1 pipeline is byte-identical across platforms.
# -----------------------------------------------------------------------------

# Mac (macOS, AVFoundation). Video device 0 + audio device 0.
# Find device indices with:
#   ffmpeg -f avfoundation -list_devices true -i ""
# NOTE: bash sourcing requires quotes around multi-word values.
FFMPEG_INPUT_ARGS="-f avfoundation -framerate 30 -video_size 1920x1080 -i 0:0"

# Pi (Raspberry Pi OS, Video4Linux2 + ALSA). Uncomment on Pi, comment Mac line.
# Find ALSA card index with: arecord -l
# FFMPEG_INPUT_ARGS="-f v4l2 -i /dev/video0 -f alsa -i hw:2,0"

# -----------------------------------------------------------------------------
# Local paths (relative to repo root)
# -----------------------------------------------------------------------------
RECORDINGS_DIR=./recordings
LOG_DIR=./logs
PID_FILE=/tmp/fac-recorder.pid

# Disk-full guard: refuse to start recording if free space (MB) below this
DISK_SPACE_MIN_MB=500

# -----------------------------------------------------------------------------
# fac-cra API (direct-to-CDN upload via watch_ingest_register/confirm)
# Bearer token issued manually; sha256 hash stored in core.api_keys.
# -----------------------------------------------------------------------------
FAC_API_URL=https://api.foundersandcoders.com/g
FAC_API_KEY=replace-me

# -----------------------------------------------------------------------------
# Remote rsync target — legacy, used by scripts/upload.sh only.
# session.sh now calls scripts/upload-cdn.sh instead, which talks to FAC_API_URL.
# Kept as an offline fallback; REMOTE_HOST must match a Host block in ~/.ssh/config.
# -----------------------------------------------------------------------------
REMOTE_HOST=mock-hetzner
REMOTE_PATH=/recordings

# -----------------------------------------------------------------------------
# Upload retry policy
# -----------------------------------------------------------------------------
UPLOAD_MAX_ATTEMPTS=3
UPLOAD_BACKOFF_START_SECONDS=1

# -----------------------------------------------------------------------------
# facpi (Go TUI + daemon) — reads the same .env as the bash scripts.
# -----------------------------------------------------------------------------
# Identity this Pi presents to the platform when polling for scheduled events.
FAC_PI_ID=pi-studio-01

# REST base for the platform endpoints facpi polls. Distinct from FAC_API_URL
# (which is the GraphQL endpoint used by upload-cdn.sh).
FAC_API_BASE_URL=https://api.foundersandcoders.com/api

# SQLite file — upload queue, recording history, event cache.
FACPI_DB_PATH=./state.db

# Scheduler (Phase 5+)
SCHEDULE_POLL_INTERVAL_SECONDS=60
SCHEDULE_LOOKAHEAD_SECONDS=172800      # 48h
SCHEDULE_LOOKBEHIND_SECONDS=3600       # 1h clock-skew tolerance
SCHEDULER_TICK_SECONDS=5

# Interlock window for manual start near a scheduled event (Phase 5+)
INTERLOCK_WINDOW_SECONDS=1800          # 30 min
INTERLOCK_OVERRIDE_LEAD_SECONDS=300    # 5 min

# TUI poll cadence for DB refresh (Phase 3+)
TUI_REFRESH_MS=500

# Optional best-effort status reporting to platform (Phase 6)
FAC_REPORT_STATUS=false
