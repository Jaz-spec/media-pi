# -----------------------------------------------------------------------------
# ffmpeg input flags — the ONE thing that differs between Mac dev and Pi prod.
# Everything else in the Phase 1 pipeline is byte-identical across platforms.
# -----------------------------------------------------------------------------

# Mac (macOS, AVFoundation). Video device 0 + audio device 0.
# Find device indices with:
#   ffmpeg -f avfoundation -list_devices true -i ""
# NOTE: bash sourcing requires quotes around multi-word values.
FFMPEG_INPUT_ARGS="-f avfoundation -framerate 30 -video_size 1920x1080 -i 0:0"

# Pi (Raspberry Pi OS, Video4Linux2 + ALSA). Uncomment on Pi, comment Mac line.
# Find ALSA card index with: arecord -l
# FFMPEG_INPUT_ARGS="-f v4l2 -i /dev/video0 -f alsa -i hw:2,0"

# -----------------------------------------------------------------------------
# Local paths (relative to repo root)
# -----------------------------------------------------------------------------
RECORDINGS_DIR=./recordings
LOG_DIR=./logs
PID_FILE=/tmp/fac-recorder.pid

# Disk-full guard: refuse to start recording if free space (MB) below this
DISK_SPACE_MIN_MB=500

# -----------------------------------------------------------------------------
# Remote (the Docker SSH mock in Phase 1; real Hetzner later)
# REMOTE_HOST must match a Host block in ~/.ssh/config
# -----------------------------------------------------------------------------
REMOTE_HOST=mock-hetzner
REMOTE_PATH=/recordings

# -----------------------------------------------------------------------------
# Upload retry policy
# -----------------------------------------------------------------------------
UPLOAD_MAX_ATTEMPTS=3
UPLOAD_BACKOFF_START_SECONDS=1
